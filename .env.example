# Copy this file to '.env' and fill in your details for local development

# 1. Gemini API Key (Required if you run server.js in standalone mode)
# You can obtain this from the Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Local Server Port (Optional, defaults to 3000)
PORT=3000

# 3. HTTP/HTTPS Proxy (Optional, if you require a proxy to access googleapis.com)
# Example: http://127.0.0.1:7890
HTTPS_PROXY=
HTTP_PROXY=
