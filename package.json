{
  "name": "gemini-livescreen",
  "version": "1.0.2",
  "description": "基于 Gemini Live API 的 Electron 原生桌面级实时屏幕与语音辅导助手",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "electron": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "https-proxy-agent": "^7.0.0",
    "ws": "^8.17.0"
  },
  "build": {
    "appId": "com.livescreen.app",
    "productName": "LiveScreen",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "XisFool",
      "repo": "gemini-livescreen"
    },
    "win": {
      "target": "nsis",
      "icon": "electron/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "electron/**/*",
      "public/**/*",
      "server.js",
      "node_modules/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.0.0"
  }
}
